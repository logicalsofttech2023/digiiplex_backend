generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MovieStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VideoType {
  MOVIE
  TRAILER
}

model Movie {
  id               String  @id @default(uuid())
  title            String
  description      String
  shortDescription String?
  slug             String  @unique
  genres           String[]
  language         String
  releaseYear      Int
  ageRating        String   @default("U/A")
  thumbnailUrl     String?
  videoUrl         String?
  trailerUrl       String?
  duration         Int
  rating           Decimal? @db.Decimal(2, 1)
  totalViews       Int      @default(0)
  likes            Int      @default(0)
  status           MovieStatus @default(PENDING)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  cast   Cast[]
  videos Video[]
}

model Video {
  id        String   @id @default(uuid())
  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  type      VideoType
  masterUrl String?
  format    String
  createdAt DateTime @default(now())

  qualities VideoQuality[]
}

model VideoQuality {
  id        String   @id @default(uuid())
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  quality   String
  url       String
  size      Int?
  bitrate   Int?
  createdAt DateTime @default(now())
}

model Cast {
  id      String @id @default(uuid())
  name    String
  movieId String
  movie   Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
}
