generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Creator {
  id                       String   @id @default(uuid())
  name                     String
  email                    String   @unique
  password                 String
  role                     String?  @default("creator")

  emailVerified            Boolean  @default(false)
  emailVerificationToken   String?
  emailVerificationExpires DateTime?

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Genre {
  id        String   @id @default(uuid())
  name      String   @unique
  image     String
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Language {
  id        String   @id @default(uuid())
  name      String   @unique
  image     String
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MovieStatus { 
  PENDING 
  APPROVED 
  REJECTED 
}

enum VideoType {
  MOVIE
  TRAILER
}

model Movie {
  id                String   @id @default(uuid())
  title             String
  description       String
  shortDescription  String?

  slug              String   @unique

  genres            String[]
  language          String
  releaseYear       Int
  ageRating         String   @default("U/A")

  thumbnailUrl      String?
  videoUrl      String?
  trailerUrl      String?

  duration          Int
  rating            Decimal? @db.Decimal(2, 1)

  totalViews        Int      @default(0)
  likes             Int      @default(0)

  status            MovieStatus @default(PENDING)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  cast              Cast[]

  videos            Video[]
}

model Video {
  id          String   @id @default(uuid())

  movieId     String
  movie       Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  type        VideoType

  masterUrl   String?   // m3u8 master playlist
  format      String    // HLS / MP4

  createdAt   DateTime  @default(now())

  qualities   VideoQuality[]
}

model VideoQuality {
  id         String   @id @default(uuid())

  videoId    String
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  quality    String   // 360p, 480p, 720p, 1080p
  url        String   // actual file URL
  size       Int?     // optional (bytes)
  bitrate    Int?     // optional

  createdAt  DateTime @default(now())
}

model Cast {
  id       String @id @default(uuid())
  name     String

  movieId  String
  movie    Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
}