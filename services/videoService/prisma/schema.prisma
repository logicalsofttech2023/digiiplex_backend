generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model VideoCatalog {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
